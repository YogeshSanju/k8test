apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: hello-cube-ingress
  annotations:
    # This tells the NGINX controller how to handle the traffic
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  ingressClassName: nginx           # Tell Kubernetes which controller to use
  rules:
    - host: hello.argo.local.com
      http:
        paths:
          - path: /
            pathType: Prefix             # Required in the new version
            backend:
              service:
                name: hello-cube-service # The name of your service
                port:
                  number: 88             # The port of your service
